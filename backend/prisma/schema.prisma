// backend/prisma/schema.prisma

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Restaurant {
id                      String              @id @default(uuid())
    name                String

    // Relations
    users               User[]
    equipments          Equipment[]
    cookingLogs         CookingLog[]
    temperatureLogs     TemperatureLog[]    
    deliveryLogs        DeliveryLog[]
    cleaningLogs        CleaningLog[]

    createdAt           DateTime            @default(now())
    updatedAt           DateTime            @updatedAt
}

model User {
    id                  String              @id @default(uuid())
    name                String
    email               String              @unique
    password            String
    role                String              @default("STAFF")

    restaurantId        String
    restaurant          Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

    createdAt           DateTime            @default(now())
    updatedAt           DateTime            @updatedAt
}

model Equipment {
    id                  String              @id @default(uuid())
    name                String
    type                String

    restaurantId        String
    restaurant          Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

    logs                TemperatureLog[]

    createdAt           DateTime            @default(now())
    updatedAt           DateTime            @updatedAt
}

model CookingLog {
    id                  String              @id @default(uuid())
    foodItem            String
    initials            String
    cookTemp            Float?
    cookTime            String?
    reheatTemp          Float?
    reheatTime          String?
    coolingStartTime    String?
    coolingStartTemp    Float?
    coolingMiddleTime   String?
    coolingMiddleTemp   Float?
    coolingFinishTime   String?
    coolingFinishTemp   Float?

    restaurantId        String
    restaurant          Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

    createdAt           DateTime            @default(now())
}

model TemperatureLog {
    id                  String              @id @default(uuid())
    temperature         Float
    timeChecked         String              @default("Morning")
    initials            String

    equipmentId         String
    equipment           Equipment           @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

    restaurantId        String
    restaurant          Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

    createdAt           DateTime            @default(now())
}

model DeliveryLog {
    id                  String              @id @default(uuid())
    supplier            String
    invoiceNumber       String?
    temperature         Float?
    condition           String
    initials            String
    
    restaurantId        String
    restaurant          Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
    
    createdAt           DateTime            @default(now())
}

model CleaningLog {
    id           String    @id @default(uuid())
    name         String

    restaurantId String
    restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
    
    createdAt    DateTime  @default(now())    
}
