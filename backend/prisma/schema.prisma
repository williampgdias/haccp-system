// backend/prisma/schema.prisma

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Temperature Table
model Temperature {
  id                        String   @id @default(uuid())
  createdAt                 DateTime @default(now())
  unitName                  String
  timeChecked               String
  temperature               Float
  rinseTemperature          Float?
}

// Deliveries Table
model Delivery {
  id                        String   @id @default(uuid())
  createdAt                 DateTime @default(now())
  deliveryDate              String
  supplierName              String
  foodItem                  String
  batchCode                 String
  useByDate                 String
  temperature               Float
  isAppearanceAcceptable    Boolean
  isVanChecked              Boolean
  comments                  String?
  signature                 String
}

// Cleaning Schedule Table
model Cleaning {
  id                        String   @id @default(uuid())
  createdAt                 DateTime @default(now())
  weekEndingDate            String
  dateCleaned               String
  equipmentName             String
  cleanedBy                 String
}

model CookingLog {
  id                        String   @id @default(uuid())
  createdAt                 DateTime @default(now())
  foodItem                  String
  initials                  String
  
  // Cooking
  cookTemp                  Float?
  cookTime                  String?
  
  // Reheating
  reheatTemp                Float?
  reheatTime                String?
  
  // Cooling (The 120min rule)
  coolingStartTime          String?
  coolingFinishTime         String?
  coolingFinalTemp          Float?
}

// User Authentication
model User {
  id                        String   @id @default(uuid())
  name                      String
  email                     String   @unique
  password                  String
  role                      String   @default("STAFF")
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}